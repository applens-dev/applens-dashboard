      "data": {
        "label": "aws_dynamodb_table.users",
        "resourceType": "aws_dynamodb_table",
        "shortType": "DynamoDB",
        "provider": "aws",
        "address": "aws_dynamodb_table.users",
        "attributes": {
          "name": "users-table",
          "billing_mode": "PAY_PER_REQUEST",
          "hash_key": "userId",
          "key_type": "S"
        },
        "threatSurface": "internal",
        "strideFlags": {
          "spoofing": false,
          "tampering": true,
          "repudiation": false,
          "informationDisclosure": true,
          "denialOfService": true,
          "elevationOfPrivilege": false
        },
        "cvssScore": null,
        "threats": [
          {
            "category": "Information Disclosure",
            "title": "No Encryption at Rest Configured",
            "description": "DynamoDB table is configured with billing_mode=PAY_PER_REQUEST but lacks explicit KMS encryption configuration. User data (userId, records) is stored with AWS-managed keys, not customer-managed encryption, reducing control over key rotation and audit.",
            "severity": "Medium"
          },
          {
            "category": "Tampering",
            "title": "No Point-in-Time Recovery or DynamoDB Streams",
            "description": "No Point-in-Time Recovery (PITR) or DynamoDB Streams are enabled. If a compromised Lambda or unauthorized actor modifies user records, changes cannot be audited or rolled back, preventing detection and remediation of data tampering.",
            "severity": "Medium"
          },
          {
            "category": "Denial of Service",
            "title": "No DynamoDB Auto-Scaling or Burst Capacity Limits",
            "description": "PAY_PER_REQUEST billing mode has no hard throughput limits. An attacker exploiting the Lambda via the HTTP API can send unlimited requests, exhausting DynamoDB write/read capacity and incurring unbounded costs, effectively denying service.",
            "severity": "Medium"
          }
        ]
      }
    },
