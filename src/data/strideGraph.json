        "attributes": {
          "name": "lambda-exec-role",
          "trusted_service": "lambda.amazonaws.com"
        },
        "threatSurface": "iam",
        "strideFlags": {
          "spoofing": false,
          "tampering": false,
          "repudiation": false,
          "informationDisclosure": false,
          "denialOfService": false,
          "elevationOfPrivilege": true
        },
        "cvssScore": null,
        "threats": [
          {
            "category": "Elevation of Privilege",
            "title": "Overly Permissive DynamoDB Actions",
            "description": "The lambda-exec-role trusts lambda.amazonaws.com. Combined with aws_iam_role_policy.lambda_dynamo_policy granting dynamodb:PutItem and dynamodb:GetItem on the users table, a compromised Lambda can read all user records (GetItem without key restriction) and write arbitrary data (PutItem), escalating from a GET /users handler to full database modification capability.",
            "severity": "High"
          }
        ]
      }
    },
    {
      "id": "iam_role_policy_lambda_dynamo_policy",
      "type": "awsNode",
      "position": {
        "x": 560,
        "y": 580
      },
      "data": {
        "label": "aws_iam_role_policy.lambda_dynamo_policy",
        "resourceType": "aws_iam_role_policy",
        "shortType": "IAM Policy",
        "provider": "aws",
        "address": "aws_iam_role_policy.lambda_dynamo_policy",
        "attributes": {
          "name": "lambda-dynamo-policy",
          "actions": ["dynamodb:PutItem", "dynamodb:GetItem"]
        },
        "threatSurface": "iam",
        "strideFlags": {
          "spoofing": false,
          "tampering": false,
          "repudiation": false,
          "informationDisclosure": false,
          "denialOfService": false,
          "elevationOfPrivilege": true
        },
        "cvssScore": null,
        "threats": [
          {
            "category": "Elevation of Privilege",
            "title": "Unrestricted DynamoDB Actions Without Resource ARN Constraint",
            "description": "The policy grants dynamodb:PutItem and dynamodb:GetItem actions with no explicit Resource ARN constraint (implicitly grants wildcard). An attacker compromising the Lambda function can access, modify, or enumerate data in any DynamoDB table in the AWS account, not just the intended users-table.",
            "severity": "Critical"
          },
          {
            "category": "Tampering",
            "title": "No Condition on DynamoDB Operations",
            "description": "The policy lacks conditions such as StringEquals on aws:RequestedRegion or other constraints. An attacker exploiting the Lambda can execute unrestricted read/write operations on user data without additional authorization checks.",
            "severity": "High"
          }
        ]
      }
    },
