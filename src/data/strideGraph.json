        "cvssScore": null,
        "threats": [
          {
            "category": "Spoofing",
            "title": "HTTP Protocol Enables Man-in-the-Middle Attacks",
            "description": "The API Gateway is configured with protocol_type=HTTP rather than HTTPS. Attackers can intercept unencrypted traffic between clients and the API, impersonating either party and capturing or modifying requests/responses.",
            "severity": "High"
          },
          {
            "category": "Information Disclosure",
            "title": "Unencrypted Data Transmission",
            "description": "HTTP protocol exposes all request and response payloads in plaintext, including user IDs, query parameters, and response data transiting to the DynamoDB backend.",
            "severity": "High"
          },
          {
            "category": "Denial of Service",
            "title": "No Rate Limiting or Throttling",
            "description": "API Gateway HTTP API lacks explicit rate limiting or throttling configuration, allowing attackers to exhaust backend resources by sending high-volume requests to GET /users endpoint.",
            "severity": "Medium"
          }
        ]
      }
    },
